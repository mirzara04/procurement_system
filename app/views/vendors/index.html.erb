<% content_for :title, 'Vendors' %>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="card-title mb-0">Vendors</h5>
    <% if policy(Vendor.new).create? %>
      <%= link_to 'New Vendor', new_vendor_path, class: 'btn btn-primary' %>
    <% end %>
  </div>

  <div class="card-body">
    <%= search_form_for @q, class: 'mb-4' do |f| %>
      <div class="row g-3">
        <div class="col-md-3">
          <%= f.label :name_cont, 'Name Contains', class: 'form-label' %>
          <%= f.search_field :name_cont, class: 'form-control' %>
        </div>
        <div class="col-md-3">
          <%= f.label :email_cont, 'Email Contains', class: 'form-label' %>
          <%= f.search_field :email_cont, class: 'form-control' %>
        </div>
        <div class="col-md-2">
          <%= f.label :status_eq, 'Status', class: 'form-label' %>
          <%= f.select :status_eq, 
              Vendor.statuses.map { |k, v| [format_vendor_status(k), k] },
              { include_blank: 'All' }, 
              class: 'form-select' %>
        </div>
        <div class="col-md-2">
          <%= f.label :tax_id_cont, 'Tax ID', class: 'form-label' %>
          <%= f.search_field :tax_id_cont, class: 'form-control' %>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <%= f.submit 'Search', class: 'btn btn-primary me-2' %>
          <%= link_to 'Clear', vendors_path, class: 'btn btn-secondary' %>
        </div>
      </div>
    <% end %>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th><%= sort_link(@q, :name, 'Name') %></th>
            <th><%= sort_link(@q, :email, 'Email') %></th>
            <th><%= sort_link(@q, :phone, 'Phone') %></th>
            <th><%= sort_link(@q, :status, 'Status') %></th>
            <th>Rating</th>
            <th>Orders</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @vendors.each do |vendor| %>
            <tr>
              <td><%= link_to vendor.name, vendor_path(vendor) %></td>
              <td><%= vendor.email %></td>
              <td><%= vendor.phone %></td>
              <td>
                <span class="badge bg-<%= vendor_status_color(vendor.status) %>">
                  <%= format_vendor_status(vendor.status) %>
                </span>
              </td>
              <td>
                <% begin %>
                  <% if vendor.vendor_ratings.loaded? && vendor.vendor_ratings.any? %>
                    <div class="d-flex align-items-center">
                      <%= render_star_rating(vendor.average_rating) %>
                      <small class="ms-1 text-muted">
                        (<%= vendor.vendor_ratings.count %>)
                      </small>
                    </div>
                  <% else %>
                    <span class="text-muted">No ratings</span>
                  <% end %>
                <% rescue => e %>
                  <% logger.error "Error displaying vendor ratings: #{e.message}" %>
                  <span class="text-muted">Rating unavailable</span>
                <% end %>
              </td>
              <td>
                <%= vendor.purchase_orders.count %>
                (<%= number_to_currency(vendor.total_purchase_orders_amount) %>)
              </td>
              <td>
                <div class="btn-group">
                  <%= link_to vendor_path(vendor), class: 'btn btn-sm btn-info', title: 'View' do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  
                  <% if policy(vendor).edit? %>
                    <%= link_to edit_vendor_path(vendor), class: 'btn btn-sm btn-primary', title: 'Edit' do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                  <% end %>

                  <% if policy(vendor).destroy? %>
                    <%= button_to vendor_path(vendor), 
                        method: :delete, 
                        class: 'btn btn-sm btn-danger',
                        title: 'Delete',
                        form: { data: { turbo_confirm: 'Are you sure?' } } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <%= paginate @vendors %>
    </div>
  </div>
</div>

<% content_for :head do %>
  <style>
    .star-rating {
      color: #ffc107;
    }
    .star-empty {
      color: #e2e2e2;
    }
  </style>
<% end %> 