<%= form_with(model: purchase_order, local: true, class: 'needs-validation', data: { controller: 'purchase-order' }) do |f| %>
  <% if purchase_order.errors.any? %>
    <div class="alert alert-danger">
      <h6>Please fix the following errors:</h6>
      <ul>
        <% purchase_order.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <div class="card-header">
      <h5 class="card-title mb-0"><%= purchase_order.new_record? ? 'New Purchase Order' : "Edit Purchase Order ##{purchase_order.po_number}" %></h5>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :vendor_id, 'Vendor', class: 'form-label required' %>
            <%= f.collection_select :vendor_id, Vendor.active, :id, :name, 
                { prompt: 'Select Vendor' }, 
                { class: 'form-select', required: true } %>
          </div>

          <div class="mb-3">
            <%= f.label :expected_delivery_date, class: 'form-label required' %>
            <%= f.date_field :expected_delivery_date, 
                class: 'form-control',
                min: Date.current,
                required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :shipping_address, class: 'form-label required' %>
            <%= f.text_area :shipping_address, 
                class: 'form-control',
                rows: 3,
                required: true %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :payment_terms, class: 'form-label' %>
            <%= f.select :payment_terms, 
                PurchaseOrder::PAYMENT_TERMS,
                { prompt: 'Select Payment Terms' }, 
                { class: 'form-select' } %>
          </div>

          <div class="mb-3">
            <%= f.label :currency, class: 'form-label required' %>
            <%= f.select :currency, 
                PurchaseOrder::CURRENCIES,
                { selected: 'USD' }, 
                { class: 'form-select', required: true } %>
          </div>

          <div class="mb-3">
            <%= f.label :notes, class: 'form-label' %>
            <%= f.text_area :notes, 
                class: 'form-control',
                rows: 3 %>
          </div>
        </div>
      </div>

      <div class="mt-4">
        <h6>Purchase Order Items</h6>
        <div id="purchase_order_items" data-purchase-order-target="items">
          <%= f.fields_for :purchase_order_items do |item| %>
            <%= render 'purchase_order_item_fields', f: item %>
          <% end %>
          
          <div class="mt-3">
            <%= link_to_add_association 'Add Item', f, :purchase_order_items,
                class: 'btn btn-outline-primary',
                data: { 
                  association_insertion_node: '#purchase_order_items',
                  association_insertion_method: 'append',
                  action: 'cocoon:after-insert->purchase-order#itemAdded'
                } %>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex justify-content-between align-items-center">
        <div>
          <h4 class="mb-0">
            Total Amount: 
            <span class="text-primary" data-purchase-order-target="grandTotal">
              <%= number_to_currency(purchase_order.total_amount || 0) %>
            </span>
          </h4>
        </div>
        <div>
          <%= link_to 'Cancel', purchase_orders_path, class: 'btn btn-light me-2' %>
          <%= f.submit class: 'btn btn-primary' %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% content_for :head do %>
  <style>
    .required:after {
      content: " *";
      color: red;
    }
  </style>
<% end %> 