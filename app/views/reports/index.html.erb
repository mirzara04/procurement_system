<% content_for :title, 'Reports Dashboard' %>

<div class="row mb-4">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-title">Total Vendors</h6>
        <h2 class="mb-0"><%= @total_vendors %></h2>
        <small class="text-muted">Active: <%= @active_vendors %></small>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-title">Total Products</h6>
        <h2 class="mb-0"><%= @total_products %></h2>
        <small class="text-muted">Low Stock: <%= @low_stock_products %></small>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-title">Purchase Orders</h6>
        <h2 class="mb-0"><%= @total_purchase_orders %></h2>
        <small class="text-muted">Pending Approval: <%= @pending_approval_pos %></small>
      </div>
    </div>
  </div>
  
  <div class="col-md-3">
    <div class="card">
      <div class="card-body">
        <h6 class="card-title">Monthly Spend</h6>
        <h2 class="mb-0">
          <%= number_to_currency(@monthly_po_amounts.values.last || 0) %>
        </h2>
        <small class="text-muted">This Month</small>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Monthly Purchase Orders Amount</h5>
      </div>
      <div class="card-body">
        <%= line_chart @monthly_po_amounts,
            min: 0,
            thousands: ",",
            prefix: "$",
            points: false,
            colors: ["#0d6efd"] %>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Top Vendors by Spend</h5>
      </div>
      <div class="card-body">
        <div class="list-group">
          <% @top_vendors.each do |vendor| %>
            <%= link_to vendor_performance_reports_path(vendor_id: vendor.id),
                class: "list-group-item list-group-item-action" do %>
              <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1"><%= vendor.name %></h6>
                <small><%= number_to_currency(vendor.total_spend) %></small>
              </div>
              <div class="d-flex w-100 justify-content-between">
                <small class="text-muted">
                  Orders: <%= vendor.purchase_orders.count %>
                </small>
                <small class="text-muted">
                  Rating: <%= render_star_rating(vendor.average_rating) %>
                </small>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div> 