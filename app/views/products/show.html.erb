<% content_for :title, @product.name %>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Product Details</h5>
        <div>
          <% if policy(@product).edit? %>
            <%= link_to edit_product_path(@product), class: 'btn btn-primary me-2' do %>
              <i class="bi bi-pencil"></i> Edit
            <% end %>
          <% end %>
          <% if policy(@product).destroy? %>
            <%= button_to product_path(@product), 
                method: :delete, 
                class: 'btn btn-danger',
                form: { 
                  data: { turbo_confirm: 'Are you sure? This cannot be undone.' },
                  class: 'd-inline-block'
                } do %>
              <i class="bi bi-trash"></i> Delete
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="card-body">
        <div class="row">
          <div class="col-md-6">
            <dl class="row">
              <dt class="col-sm-4">SKU</dt>
              <dd class="col-sm-8"><%= @product.sku %></dd>

              <dt class="col-sm-4">Status</dt>
              <dd class="col-sm-8">
                <span class="badge bg-<%= product_status_color(@product.status) %>">
                  <%= @product.status.present? %>
                </span>
              </dd>

              <dt class="col-sm-4">Category</dt>
              <dd class="col-sm-8"><%= @product.category.present? %></dd>

              <dt class="col-sm-4">Unit Price</dt>
              <dd class="col-sm-8"><%= number_to_currency(@product.unit_price) %></dd>
            </dl>
          </div>

          <div class="col-md-6">
            <dl class="row">
              <dt class="col-sm-4">Current Stock</dt>
              <dd class="col-sm-8">
                <%= @product.current_stock %>
                <% if @product.low_stock? %>
                  <span class="badge bg-warning">Low Stock</span>
                <% end %>
              </dd>

              <dt class="col-sm-4">Reorder Point</dt>
              <dd class="col-sm-8"><%= @product.reorder_point || 'Not set' %></dd>

              <dt class="col-sm-4">Min. Order Qty</dt>
              <dd class="col-sm-8"><%= @product.minimum_order_quantity || 'Not set' %></dd>

              <dt class="col-sm-4">Vendor</dt>
              <dd class="col-sm-8">
                <% if @product.vendor %>
                  <%= link_to @product.vendor.name, vendor_path(@product.vendor) %>
                <% else %>
                  <span class="text-muted">Not assigned</span>
                <% end %>
              </dd>
            </dl>
          </div>
        </div>

        <% if @product.description.present? %>
          <div class="mt-4">
            <h6>Description</h6>
            <p class="mb-0"><%= simple_format @product.description %></p>
          </div>
        <% end %>

        <div class="mt-4">
          <h6>Order History</h6>
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Order #</th>
                  <th>Date</th>
                  <th>Vendor</th>
                  <th class="text-center">Quantity</th>
                  <th class="text-end">Unit Price</th>
                  <th class="text-end">Total</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% @product.purchase_order_items.includes(:purchase_order).order('purchase_orders.created_at DESC').each do |item| %>
                  <tr>
                    <td>
                      <%= link_to item.purchase_order.po_number, 
                          purchase_order_path(item.purchase_order) %>
                    </td>
                    <td><%= l item.purchase_order.created_at.to_date %></td>
                    <td><%= item.purchase_order.vendor.name %></td>
                    <td class="text-center"><%= item.quantity %></td>
                    <td class="text-end"><%= number_to_currency(item.unit_price) %></td>
                    <td class="text-end"><%= number_to_currency(item.total_price) %></td>
                    <td>
                      <span class="badge bg-<%= order_status_color(item.purchase_order.status) %>">
                        <%= item.purchase_order.status.present? %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card mb-4">
      <div class="card-body">
        <h6 class="card-title">Statistics</h6>
        <dl class="row mb-0">
          <dt class="col-sm-8">Total Orders</dt>
          <dd class="col-sm-4 text-end"><%= @product.purchase_order_items.count %></dd>

          <dt class="col-sm-8">Total Quantity Ordered</dt>
          <dd class="col-sm-4 text-end"><%= @product.total_ordered_quantity %></dd>

          <dt class="col-sm-8">Total Amount Ordered</dt>
          <dd class="col-sm-4 text-end"><%= number_to_currency(@product.total_ordered_amount) %></dd>
        </dl>
      </div>
    </div>

    <% if @product.notes.present? %>
      <div class="card">
        <div class="card-body">
          <h6 class="card-title">Notes</h6>
          <p class="card-text mb-0"><%= simple_format @product.notes %></p>
        </div>
      </div>
    <% end %>
  </div>
</div> 