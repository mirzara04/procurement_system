<% content_for :title, 'Vendor Performance' %>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="card-title mb-0">Vendor Performance</h5>
    <%= link_to 'Back to Reports', reports_path, class: 'btn btn-primary' %>
  </div>
  <div class="card-body">
    <p class="text-muted">Select a vendor to view their performance report.</p>

    <div class="list-group">
      <% @vendors.each do |vendor| %>
        <%= link_to vendor_performance_reports_path(vendor_id: vendor.id),
            class: 'list-group-item list-group-item-action d-flex justify-content-between align-items-center' do %>
          <div>
            <strong><%= vendor.name %></strong>
            <small class="text-muted ms-2"><%= vendor.email %></small>
          </div>
          <div class="text-end">
            <span class="badge bg-secondary me-2"><%= vendor.purchase_orders.count %> orders</span>
            <span class="badge bg-success"><%= number_to_currency(vendor.total_purchase_orders_amount) %></span>
          </div>
        <% end %>
      <% end %>

      <% if @vendors.empty? %>
        <div class="text-center py-4 text-muted">No active vendors found.</div>
      <% end %>
    </div>
  </div>
</div>
