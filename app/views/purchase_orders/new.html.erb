<% content_for :title, 'New Purchase Order' %>

<div class="card">
  <div class="card-header">
    <h5 class="card-title mb-0">New Purchase Order</h5>
  </div>

  <div class="card-body">
    <%= form_with(model: @purchase_order, local: true, class: 'needs-validation') do |f| %>
      <% if @purchase_order.errors.any? %>
        <div class="alert alert-danger">
          <h6>Please fix the following errors:</h6>
          <ul>
            <% @purchase_order.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :vendor_id, 'Vendor', class: 'form-label required' %>
            <%= f.collection_select :vendor_id, Vendor.active_vendors, :id, :name, 
                { prompt: 'Select a vendor' }, 
                { class: 'form-select', required: true } %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :expected_delivery_date, class: 'form-label required' %>
            <%= f.date_field :expected_delivery_date, 
                class: 'form-control',
                min: Date.current,
                required: true %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :payment_terms, class: 'form-label' %>
            <%= f.select :payment_terms, 
                PurchaseOrder::PAYMENT_TERMS,
                { include_blank: 'Select payment terms' },
                { class: 'form-select' } %>
          </div>
        </div>

        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :currency, class: 'form-label required' %>
            <%= f.select :currency, 
                PurchaseOrder::CURRENCIES,
                { selected: 'USD' },
                { class: 'form-select', required: true } %>
          </div>
        </div>

        <div class="col-12">
          <div class="mb-3">
            <%= f.label :shipping_address, class: 'form-label required' %>
            <%= f.text_area :shipping_address, 
                class: 'form-control',
                rows: 3,
                required: true %>
          </div>
        </div>

        <div class="col-12">
          <div class="mb-3">
            <%= f.label :notes, class: 'form-label' %>
            <%= f.text_area :notes, 
                class: 'form-control',
                rows: 3 %>
          </div>
        </div>
      </div>

      <h6 class="mt-4 mb-3">Purchase Order Items</h6>
      <div id="purchase_order_items">
        <%= f.fields_for :purchase_order_items do |item| %>
          <%= render 'purchase_order_item_fields', f: item %>
        <% end %>

        <div class="links mb-3">
          <%= link_to_add_association 'Add Item', f, :purchase_order_items,
              class: 'btn btn-outline-primary',
              partial: 'purchase_order_item_fields' %>
        </div>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <%= link_to 'Cancel', purchase_orders_path, class: 'btn btn-light' %>
        <%= f.submit 'Create Purchase Order', class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
</div>

<% content_for :javascript do %>
  <script>
    document.addEventListener('turbo:load', function() {
      // Initialize any JavaScript components (e.g., select2, datepicker) here
    });
  </script>
<% end %> 