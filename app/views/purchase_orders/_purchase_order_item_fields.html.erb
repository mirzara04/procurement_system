<div class="nested-fields border rounded p-3 mb-3" data-purchase-order-target="items">
  <div class="row g-3">
    <div class="col-md-4">
      <div class="mb-3">
        <%= f.label :product_id, 'Product', class: 'form-label required' %>
        <%= f.collection_select :product_id, 
            Product.where(status: 'active'), 
            :id, 
            ->(p) { "#{p.name} (#{p.sku})" }, 
            { prompt: 'Select a product' }, 
            { class: 'form-select product-select', required: true } %>
      </div>
    </div>

    <div class="col-md-2">
      <div class="mb-3">
        <%= f.label :quantity, class: 'form-label required' %>
        <%= f.number_field :quantity, 
            class: 'form-control quantity-field',
            min: 1,
            required: true,
            data: { action: 'change->purchase-order#recalculate' } %>
      </div>
    </div>

    <div class="col-md-3">
      <div class="mb-3">
        <%= f.label :unit_price, class: 'form-label required' %>
        <%= f.number_field :unit_price, 
            class: 'form-control unit-price-field',
            min: 0.01,
            step: 0.01,
            required: true,
            data: { action: 'change->purchase-order#recalculate' } %>
      </div>
    </div>

    <div class="col-md-3">
      <div class="mb-3">
        <%= f.label :total_price, class: 'form-label' %>
        <%= f.number_field :total_price, 
            class: 'form-control total-price-field',
            readonly: true %>
      </div>
    </div>

    <div class="col-12">
      <div class="mb-3">
        <%= f.label :description, class: 'form-label' %>
        <%= f.text_area :description, 
            class: 'form-control',
            rows: 2 %>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-end">
    <%= link_to_remove_association 'Remove Item', f,
        class: 'btn btn-outline-danger btn-sm',
        data: { action: 'click->purchase-order#itemRemoved' } %>
  </div>
</div>

<script>
  // Calculate total price when quantity or unit price changes
  document.querySelectorAll('.nested-fields').forEach(function(field) {
    const quantityField = field.querySelector('[name*="[quantity]"]');
    const unitPriceField = field.querySelector('[name*="[unit_price]"]');
    const totalPriceField = field.querySelector('[name*="[total_price]"]');

    function calculateTotal() {
      const quantity = parseFloat(quantityField.value) || 0;
      const unitPrice = parseFloat(unitPriceField.value) || 0;
      totalPriceField.value = (quantity * unitPrice).toFixed(2);
    }

    quantityField.addEventListener('change', calculateTotal);
    unitPriceField.addEventListener('change', calculateTotal);
  });
</script> 