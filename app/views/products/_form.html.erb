<%= form_with(model: product, class: 'needs-validation') do |f| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger">
      <h6>Please fix the following errors:</h6>
      <ul class="mb-0">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="mb-3">
            <%= f.label :name, class: 'form-label required' %>
            <%= f.text_field :name, class: 'form-control', required: true %>
          </div>
        </div>

        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :sku, 'SKU', class: 'form-label required' %>
            <%= f.text_field :sku, class: 'form-control', required: true %>
          </div>
        </div>

        <div class="col-md-3">
          <div class="mb-3">
            <%= f.label :status, class: 'form-label required' %>
            <%= f.select :status, 
                Product.statuses.map { |k, v| [k.titleize, k] },
                { prompt: 'Select status' },
                { class: 'form-select', required: true } %>
          </div>
        </div>

        <div class="col-md-12">
          <div class="mb-3">
            <%= f.label :description, class: 'form-label' %>
            <%= f.text_area :description, class: 'form-control', rows: 3 %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :category, class: 'form-label required' %>
            <%= f.select :category,
                Product.categories.map { |k, v| [k.titleize, k] },
                { prompt: 'Select category' },
                { class: 'form-select', required: true } %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :vendor_id, 'Vendor', class: 'form-label' %>
            <%= f.collection_select :vendor_id,
                Vendor.active_vendors,
                :id,
                :name,
                { prompt: 'Select vendor (optional)' },
                { class: 'form-select' } %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :unit_price, class: 'form-label required' %>
            <%= f.number_field :unit_price,
                class: 'form-control',
                min: 0,
                step: 0.01,
                required: true %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :current_stock, class: 'form-label required' %>
            <%= f.number_field :current_stock,
                class: 'form-control',
                min: 0,
                required: true %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :reorder_point, class: 'form-label' %>
            <%= f.number_field :reorder_point,
                class: 'form-control',
                min: 0 %>
            <div class="form-text">Stock level at which to reorder</div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="mb-3">
            <%= f.label :minimum_order_quantity, class: 'form-label' %>
            <%= f.number_field :minimum_order_quantity,
                class: 'form-control',
                min: 1 %>
            <div class="form-text">Minimum quantity per order</div>
          </div>
        </div>

        <div class="col-12">
          <div class="mb-3">
            <%= f.label :notes, class: 'form-label' %>
            <%= f.text_area :notes, class: 'form-control', rows: 3 %>
          </div>
        </div>
      </div>
    </div>

    <div class="card-footer text-end">
      <%= link_to 'Cancel', products_path, class: 'btn btn-secondary me-2' %>
      <%= f.submit class: 'btn btn-primary' %>
    </div>
  </div>
<% end %> 